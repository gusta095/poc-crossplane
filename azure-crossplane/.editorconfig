root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# Example: file.json, file.json.tpl
[*.{json,yml,yaml}{,.tpl}]
indent_size = 2
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 160

[*.md]
indent_size = 2
max_line_length = 160
trim_trailing_whitespace = true

[Makefile]
indent_style = tab
